{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://github.com/xiqin/loom/config/pipeline.schema.json",
  "title": "loom Pipeline State Machine",
  "description": "功能级流水线状态定义。每个 specs/<date+feature>/ 目录对应一个功能实例，独立跟踪状态。",
  "version": 1,
  "states": {
    "brainstorming": {
      "step": 1,
      "skill": "loom-brainstorming",
      "command": "loom-brainstorm",
      "description": "需求头脑风暴，探索 2-3 种实现方案",
      "allowedTransitions": [
        "planning",
        "failed"
      ],
      "preconditions": [
        {
          "type": "input",
          "description": "用户提供需求描述",
          "check": "requirement 非空"
        }
      ],
      "outputs": [
        {
          "path": "specs/<date+feature>/spec.md",
          "action": "created"
        },
        {
          "path": "specs/<date+feature>/progress.md",
          "action": "created"
        }
      ],
      "reads": [
        ".loom/rules/constitution.md"
      ],
      "interactive": true,
      "autoTransition": false,
      "nextOnSuccess": "等待用户确认 spec 后转 planning",
      "banner": "执行中：loom-brainstorming"
    },
    "planning": {
      "step": 2,
      "skill": "loom-writing-plans",
      "command": "loom-write-plan",
      "description": "按项目架构分层拆解 task",
      "allowedTransitions": [
        "approved",
        "failed"
      ],
      "preconditions": [
        {
          "type": "file",
          "description": "spec.md 存在且用户已确认",
          "check": "specs/<date+feature>/spec.md 存在"
        }
      ],
      "outputs": [
        {
          "path": "specs/<date+feature>/plan.md",
          "action": "created",
          "note": "摘要 + Task 概览表"
        },
        {
          "path": "specs/<date+feature>/tasks/",
          "action": "created",
          "note": "独立 task 文件目录，每个 task 一个文件（T1.md, T2.md, ...）"
        },
        {
          "path": "specs/<date+feature>/progress.md",
          "action": "modified"
        }
      ],
      "reads": [
        "specs/<date+feature>/spec.md",
        ".loom/rules/constitution.md"
      ],
      "interactive": true,
      "autoTransition": false,
      "nextOnSuccess": "等待用户确认 plan 后转 approved",
      "banner": "执行中：loom-writing-plans"
    },
    "approved": {
      "step": null,
      "skill": null,
      "command": null,
      "description": "用户已确认计划，等待执行（检查点状态）",
      "allowedTransitions": [
        "executing",
        "failed"
      ],
      "preconditions": [
        {
          "type": "file",
          "description": "plan.md 和 tasks 目录存在且用户已确认",
          "check": "specs/<date+feature>/plan.md 存在且 specs/<date+feature>/tasks/ 目录存在"
        },
        {
          "type": "file",
          "description": "spec.md 存在",
          "check": "specs/<date+feature>/spec.md 存在"
        }
      ],
      "outputs": [],
      "reads": [],
      "interactive": false,
      "autoTransition": false,
      "nextOnSuccess": "用户触发 loom-execute-plan 后转 executing",
      "banner": null
    },
    "git-worktree": {
      "step": 3,
      "skill": "loom-using-git-worktrees",
      "command": "loom-execute-plan",
      "description": "创建隔离分支",
      "allowedTransitions": [
        "executing",
        "failed"
      ],
      "preconditions": [
        {
          "type": "file",
          "description": "plan.md 和 tasks 目录存在且用户已确认",
          "check": "specs/<date+feature>/plan.md 存在且 specs/<date+feature>/tasks/ 目录存在"
        },
        {
          "type": "file",
          "description": "spec.md 存在",
          "check": "specs/<date+feature>/spec.md 存在"
        }
      ],
      "outputs": [
        {
          "path": "feature/<date>-<name> 分支",
          "action": "created"
        },
        {
          "path": "specs/<date+feature>/progress.md",
          "action": "modified"
        }
      ],
      "reads": [
        ".loom/rules/constitution.md"
      ],
      "interactive": false,
      "autoTransition": false,
      "nextOnSuccess": "分支创建成功后转 executing",
      "banner": "执行中：loom-using-git-worktrees"
    },
    "executing": {
      "step": 4,
      "skill": "loom-subagent-driven-development",
      "command": null,
      "description": "Subagent 编码执行（隔离派发 + 合并审查 + 增量修复）",
      "allowedTransitions": [
        "verification",
        "failed"
      ],
      "preconditions": [
        {
          "type": "file",
          "description": "plan.md 和 tasks 目录存在",
          "check": "specs/<date+feature>/plan.md 存在且 specs/<date+feature>/tasks/ 目录存在"
        },
        {
          "type": "git",
          "description": "worktree 已创建",
          "check": "git worktree 存在"
        }
      ],
      "outputs": [
        {
          "path": "源码文件",
          "action": "created/modified"
        },
        {
          "path": "单元测试文件",
          "action": "created/modified",
          "note": "implementer 编写，持久化到项目标准测试目录"
        },
        {
          "path": "集成测试文件",
          "action": "created/modified",
          "note": "test-reporter 编写，持久化到项目标准测试目录"
        },
        {
          "path": "specs/<date+feature>/test-report.md",
          "action": "created",
          "note": "包含集成测试、回归测试和Spec验证结果"
        },
        {
          "path": "specs/<date+feature>/progress.md",
          "action": "modified"
        }
      ],
      "reads": [
        "specs/<date+feature>/plan.md",
        "specs/<date+feature>/tasks/",
        "specs/<date+feature>/spec.md",
        ".loom/contexts/subagent-context.md",
        ".loom/rules/constitution.md"
      ],
      "interactive": true,
      "autoTransition": false,
      "nextOnSuccess": "所有 task 完成后转 verification",
      "banner": "执行中：loom-subagent-driven-development",
      "subStates": {
        "implementer": {
          "description": "Subagent 编码实现",
          "statuses": [
            "DONE",
            "DONE_WITH_CONCERNS",
            "NEEDS_CONTEXT",
            "BLOCKED"
          ],
          "modes": [
            {
              "mode": "首次实现模式",
              "description": "从零开始实现完整 task，接收完整 task 定义和 spec 上下文"
            },
            {
              "mode": "修复模式",
              "description": "基于修复指令精准修复问题，只接收修复指令 + subagent-context，不重新传递完整 task 和 spec"
            }
          ]
        },
        "reviewer": {
          "description": "Spec + 代码质量合并审查",
          "verdicts": [
            "PASS",
            "FAIL"
          ],
          "failOutput": "修复指令（结构化的问题定位和修复方向）"
        }
      }
    },
    "verification": {
      "step": 5,
      "skill": "loom-verification-before-completion",
      "command": null,
      "description": "完成前验证（前置产出核验、编译验证、占位符扫描、类型一致性、最终一致性核验）",
      "allowedTransitions": [
        "synced",
        "executing",
        "failed"
      ],
      "preconditions": [
        {
          "type": "file",
          "description": "test-report.md 存在且结论为 PASS",
          "check": "specs/<date+feature>/test-report.md 存在且结论为 PASS"
        },
        {
          "type": "file",
          "description": "combined-reviewer 报告存在且判定为通过",
          "check": "存在 reviewer 通过判定"
        }
      ],
      "outputs": [
        {
          "path": "验证报告",
          "action": "created"
        },
        {
          "path": "specs/<date+feature>/verify-report.md",
          "action": "created"
        },
        {
          "path": "specs/<date+feature>/progress.md",
          "action": "modified"
        }
      ],
      "reads": [
        "specs/<date+feature>/spec.md",
        "specs/<date+feature>/plan.md",
        "specs/<date+feature>/tasks/",
        "specs/<date+feature>/test-report.md",
        "combined-reviewer 报告",
        ".loom/rules/constitution.md",
        "源码文件"
      ],
      "interactive": true,
      "autoTransition": false,
      "nextOnSuccess": "验证通过后转 synced",
      "banner": "执行中：loom-verification-before-completion",
      "retryOnFail": {
        "target": "executing",
        "condition": "BLOCKER 存在时派回 implementer 修复",
        "fixMode": true,
        "fixModeDescription": "增量修复模式：只派发 implementer（修复模式），传递修复指令 + subagent-context.md，不重新传递完整 task 上下文和 spec 全文"
      }
    },
    "synced": {
      "step": 6,
      "skill": "loom-index-update",
      "command": null,
      "description": "codegraph 同步与结构化记忆更新，功能开发完成",
      "allowedTransitions": [],
      "preconditions": [
        {
          "type": "review",
          "description": "验证通过",
          "check": "verification 结果为 PASS"
        },
        {
          "type": "test",
          "description": "所有测试通过",
          "check": "测试套件 exit code 0"
        }
      ],
      "outputs": [
        {
          "path": ".codegraph/",
          "action": "modified",
          "note": "仅启用 codegraph 时通过 loom index 同步；未启用时跳过"
        },
        {
          "path": ".loom/memory/store.json",
          "action": "modified"
        },
        {
          "path": ".loom/memory/MEMORY.md",
          "action": "generated",
          "note": "需要提交导出视图时由 loom memory export 生成"
        },
        {
          "path": "specs/<date+feature>/progress.md",
          "action": "modified"
        }
      ],
      "reads": [
        ".loom/memory/store.json",
        "源码文件"
      ],
      "interactive": false,
      "autoTransition": false,
      "nextOnSuccess": "通知用户可以提交 PR",
      "banner": "执行中：loom-index-update"
    },
    "failed": {
      "step": null,
      "skill": null,
      "command": null,
      "description": "流水线失败（任意阶段）",
      "allowedTransitions": [
        "brainstorming",
        "executing",
        "verification"
      ],
      "preconditions": [],
      "outputs": [
        {
          "path": "specs/<date+feature>/progress.md",
          "action": "modified"
        }
      ],
      "reads": [],
      "interactive": true,
      "autoTransition": false,
      "nextOnSuccess": null,
      "banner": null,
      "recovery": {
        "fromBrainstorming": "重新执行 loom-brainstorm",
        "fromPlanning": "重新执行 loom-write-plan",
        "fromExecuting": "修复问题后重新执行 loom-execute-plan",
        "fromVerification": "修复 BLOCKER 后重新验证"
      }
    }
  },
  "transitions": [
    {
      "from": "brainstorming",
      "to": "planning",
      "trigger": "user_confirms_spec",
      "description": "用户确认 spec.md"
    },
    {
      "from": "brainstorming",
      "to": "failed",
      "trigger": "error",
      "description": "brainstorming 失败"
    },
    {
      "from": "planning",
      "to": "approved",
      "trigger": "user_confirms_plan",
      "description": "用户确认 plan.md"
    },
    {
      "from": "planning",
      "to": "failed",
      "trigger": "error",
      "description": "planning 失败"
    },
    {
      "from": "approved",
      "to": "git-worktree",
      "trigger": "user_triggers_execute",
      "description": "用户执行 loom-execute-plan"
    },
    {
      "from": "approved",
      "to": "failed",
      "trigger": "error",
      "description": "执行前检查失败"
    },
    {
      "from": "git-worktree",
      "to": "executing",
      "trigger": "worktree_created",
      "description": "worktree 创建成功，触发 subagent"
    },
    {
      "from": "git-worktree",
      "to": "failed",
      "trigger": "error",
      "description": "worktree 创建失败"
    },
    {
      "from": "executing",
      "to": "verification",
      "trigger": "all_tasks_done",
      "description": "所有 task 完成，进入验证"
    },
    {
      "from": "executing",
      "to": "failed",
      "trigger": "test_failure|blocker",
      "description": "测试失败或 BLOCKED 状态"
    },
    {
      "from": "verification",
      "to": "synced",
      "trigger": "verification_pass",
      "description": "验证通过"
    },
    {
      "from": "verification",
      "to": "executing",
      "trigger": "blocker_found",
      "description": "BLOCKER 派回 implementer 修复（增量模式：只传递修复指令 + subagent-context）",
      "fixMode": true
    },
    {
      "from": "verification",
      "to": "failed",
      "trigger": "critical_failure",
      "description": "验证发现 Critical 偏差"
    },
    {
      "from": "failed",
      "to": "brainstorming",
      "trigger": "user_restarts",
      "description": "从头重新开始"
    },
    {
      "from": "failed",
      "to": "executing",
      "trigger": "user_retries",
      "description": "修复后重试执行"
    },
    {
      "from": "failed",
      "to": "verification",
      "trigger": "user_retries_verification",
      "description": "修复后重试验证"
    }
  ],
  "progressFileFormat": {
    "path": "specs/<date+feature>/progress.md",
    "statusValues": {
      "waiting": {
        "symbol": "⏳",
        "label": "等待",
        "description": "尚未开始"
      },
      "running": {
        "symbol": "▶",
        "label": "进行中",
        "description": "正在执行"
      },
      "done": {
        "symbol": "✅",
        "label": "完成",
        "description": "已完成"
      },
      "failed": {
        "symbol": "❌",
        "label": "失败",
        "description": "执行失败"
      }
    }
  }
}
