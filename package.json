{
  "name": "loom-engineering",
  "version": "2.0.2",
  "description": "Loom — AI 工程化框架",
  "type": "module",
  "main": "./plugin.mjs",
  "license": "MIT",
  "keywords": [
    "ai",
    "engineering",
    "skills",
    "pipeline",
    "tdd",
    "chinese",
    "loom"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/xiqin/loom.git"
  },
  "bugs": {
    "url": "https://github.com/xiqin/loom/issues"
  },
  "homepage": "https://github.com/xiqin/loom#readme",
  "bin": {
    "loom": "bin/loom.js"
  },
  "files": [
    "bin/",
    "src/",
    "skills/",
    "commands/",
    "core/",
    "hooks/",
    "templates/",
    ".claude-plugin/",
    "scripts/common.sh",
    "scripts/common.ps1",
    "plugin.mjs",
    "install.sh",
    "install.ps1",
    "uninstall.sh",
    "uninstall.ps1",
    "config/",
    "docs/"
  ],
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "generate": "node scripts/generate-incremental.mjs",
    "generate:force": "node scripts/generate-incremental.mjs --force",
    "generate:check": "node scripts/generate-incremental.mjs --check",
    "generate:catalog": "node scripts/generate-skills-catalog.mjs",
    "generate:model-selection": "node scripts/generate-model-selection.mjs",
    "generate:rules": "node scripts/generate-shared-rules.mjs",
    "generate:review": "node scripts/generate-review-summary.mjs",
    "sync-version": "node scripts/sync-version.mjs",
    "sync-version:check": "node scripts/sync-version.mjs --check",
    "test:skills": "node skills/loom-writing-skills/scripts/lint-skills.mjs",
    "pretest": "node scripts/generate-incremental.mjs",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepack": "node scripts/generate-incremental.mjs --force && node scripts/generate-plugin-meta.mjs && node scripts/sync-version.mjs && npm test",
    "prepublishOnly": "node scripts/generate-incremental.mjs --force && node scripts/generate-plugin-meta.mjs && node scripts/sync-version.mjs && npm test"
  },
  "dependencies": {
    "commander": "^12.0.0"
  },
  "devDependencies": {
    "@vitest/coverage-v8": "^3.2.4",
    "vitest": "^3.0.0"
  },
  "mcpServers": {
    "loom": {
      "command": "loom",
      "args": [
        "mcp-serve"
      ],
      "description": "Loom AI engineering framework MCP server"
    }
  }
}
