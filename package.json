{
  "name": "loom-engineering",
  "version": "1.3.0",
  "description": "Loom — AI 工程化框架",
  "type": "module",
  "main": "./plugin.mjs",
  "license": "MIT",
  "keywords": [
    "ai",
    "engineering",
    "skills",
    "pipeline",
    "tdd",
    "chinese",
    "loom"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/xiqin/loom"
  },
  "bugs": {
    "url": "https://github.com/xiqin/loom/issues"
  },
  "homepage": "https://github.com/xiqin/loom#readme",
  "bin": {
    "loom": "./bin/loom.js"
  },
  "files": [
    "bin/",
    "src/",
    "skills/",
    "commands/",
    "core/",
    "hooks/",
    "templates/",
    "plugin-meta/",
    ".claude-plugin/",
    "plugin.mjs",
    "install.sh",
    "install.ps1",
    "uninstall.sh",
    "uninstall.ps1"
  ],
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "generate": "node scripts/generate-tooling.mjs && node scripts/generate-plugin-meta.mjs",
    "sync-version": "node scripts/sync-version.mjs",
    "sync-version:check": "node scripts/sync-version.mjs --check",
    "pretest": "node scripts/generate-tooling.mjs",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepack": "node scripts/generate-plugin-meta.mjs && node scripts/sync-version.mjs && npm test",
    "prepublishOnly": "node scripts/generate-plugin-meta.mjs && node scripts/sync-version.mjs && npm test"
  },
  "dependencies": {
    "commander": "^12.0.0"
  },
  "devDependencies": {
    "@vitest/coverage-v8": "^3.2.4",
    "vitest": "^3.0.0"
  }
}
